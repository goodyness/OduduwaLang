{
    "name": "oduduwa",
    "displayName": "OduduwaLang",
    "description": "Yoruba-first programming language support",
    "version": "0.2.0",
    "publisher": "AdediranAdedamola",
    "repository": {
        "type": "git",
        "url": "https://github.com/goodyness/OduduwaLang.git"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "icon": "icon.png",
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "oduduwa",
                "aliases": [
                    "Oduduwa",
                    "oduduwa"
                ],
                "extensions": [
                    ".odu"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icon.png",
                    "dark": "./icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "oduduwa",
                "scopeName": "source.oduduwa",
                "path": "./syntaxes/oduduwa.tmLanguage.json"
            }
        ]
    }
}